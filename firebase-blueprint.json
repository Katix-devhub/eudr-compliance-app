{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "A supplier profile for EUDR compliance management.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Legal name of the producer or cooperative." },
        "coop": { "type": "string", "description": "Cooperative membership if applicable." },
        "product": { "type": "string", "description": "The specific commodity (Coffee, Cocoa, etc.)." },
        "country": { "type": "string", "description": "Country of origin." },
        "region": { "type": "string", "description": "Specific region or department." },
        "qty": { "type": "string", "description": "Estimated annual quantity." },
        "date": { "type": "string", "description": "Last harvest date." },
        "lat": { "type": "string", "description": "Centroid latitude of the plot." },
        "lng": { "type": "string", "description": "Centroid longitude of the plot." },
        "area": { "type": "string", "description": "Surface area in hectares." },
        "cert": { "type": "string", "description": "List of active certifications." },
        "hsCode": { "type": "string", "description": "EU Customs Harmonized System code." },
        "type": { "type": "string", "enum": ["individual", "cooperative"], "description": "Type of legal entity." },
        "status": { "type": "string", "enum": ["ok", "pending", "alert", "new"], "description": "Compliance status." },
        "ref": { "type": "string", "description": "Internal unique compliance reference." },
        "email": { "type": "string", "format": "email", "description": "Contact email for automated follow-ups." },
        "lang": { "type": "string", "description": "Primary communication language." },
        "risk": { "type": "string", "enum": ["high", "standard", "low"], "description": "Commission benchmark risk level." },
        "userId": { "type": "string", "description": "Owner UID for data isolation." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["name", "country", "product", "userId", "ref", "status"]
    },
    "User": {
      "title": "User",
      "description": "System user account for the Traverdy platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["operator", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Main collection for managing deforestation risk and compliance of suppliers."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions."
    }
  }
}
